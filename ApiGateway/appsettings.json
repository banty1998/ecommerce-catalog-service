{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Information",
      "Yarp": "Information"
    }
  },
  "JwtOptions": {
    "Secret": "YourSuperSecretKeyThatIsAtLeast32BytesLongForEcommerceClone!",
    "Issuer": "ecommerce-auth-api",
    "Audience": "ecommerce-client"
  },
  "AllowedHosts": "*",
  "ReverseProxy": {
    "Routes": {
      "product-readonly-route": {
        "ClusterId": "product-cluster",
        "RateLimiterPolicy": "FixedPolicy",
        "Match": {
          "Path": "/api/Product/{**catch-all}",
          "Methods": [ "GET" ]
        }
      },
      "product-write-route": {
        "ClusterId": "product-cluster",
        "AuthorizationPolicy": "default",
        "RateLimiterPolicy": "FixedPolicy",
        "Match": {
          "Path": "/api/Product/{**catch-all}",
          "Methods": [ "POST", "PUT", "DELETE" ]
        }
      },
      "order-route": {
        "ClusterId": "order-cluster",
        "AuthorizationPolicy": "default",
        "RateLimiterPolicy": "FixedPolicy",
        "Match": {
          "Path": "/api/Orders/{**catch-all}"
        }
      },
      "auth-route": {
        "ClusterId": "auth-cluster",
        "RateLimiterPolicy": "FixedPolicy",
        "Match": {
          "Path": "/api/auth/{**catch-all}"
        }
      }
    },
    "Clusters": {
      "product-cluster": {
        "Destinations": {
          "destination1": {
            "Address": "http://product-api:8080"
          }
        }
      },
      "order-cluster": {
        "Destinations": {
          "destination1": {
            "Address": "http://order-api:8080"
          }
        }
      },
      "auth-cluster": {
        "Destinations": {
          "destination1": {
            "Address": "http://auth-api:8080"
          }
        }
      }
    }
  }
}